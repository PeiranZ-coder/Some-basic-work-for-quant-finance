-0.0067 & 0.0097 & -0.0054 & 0.0078 & 0.0030 \\
-0.0053 & -0.0159 & -0.0096 & 0.0000 & -0.0055 \\
0.0095 & 0.0361 & -0.0023 & -0.0037 & -0.0060 \\
